# Coolify → docker-compose.coolify.yml (NO build on server)

POSTGRES_USER=progress
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=progress_sheet
JWT_SECRET=change-me-long-random-secret

# Imágenes publicadas por GitHub Actions (reemplazá TU_USUARIO)
BACKEND_IMAGE=ghcr.io/tu-usuario/progress-sheet-backend:latest
WEB_IMAGE=ghcr.io/tu-usuario/progress-sheet-web:latest

# URL pública del API (sufijo /api). El servicio web la recibe como API_BASE_URL en runtime.
NEXT_PUBLIC_API_URL=https://api.tudominio.com/api

# Opcional: fijar imagen por commit (evita caché de :latest en el VPS)
# WEB_IMAGE=ghcr.io/tu-usuario/progress-sheet-web:COMMIT_SHA
