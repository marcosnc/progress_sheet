# Copy to .env before deploy (Coolify: set these in Environment Variables)

# PostgreSQL
POSTGRES_USER=progress
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=progress_sheet

# Backend
JWT_SECRET=change-me-long-random-secret

# Web — URL del API vista desde el navegador (sufijo /api obligatorio)
NEXT_PUBLIC_API_URL=http://localhost:3001/api
# En producción: NEXT_PUBLIC_API_URL=https://api.tudominio.com/api

# Puertos en el host (pruebas locales)
WEB_PORT=3000
API_PORT=3001
