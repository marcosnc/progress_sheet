# Copy to .env before deploy (Coolify: set these in Environment Variables)

# PostgreSQL
POSTGRES_USER=progress
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=progress_sheet

# Backend
JWT_SECRET=change-me-long-random-secret

# Web — URL del API vista desde el navegador (sufijo /api obligatorio)
# Docker Compose local: web en :3000 reenvía /api al backend (ver next.config.ts)
API_BASE_URL=/api
# Dev sin Docker (solo pnpm dev): opcional si no usás rewrites
# API_BASE_URL=http://localhost:3001/api

# Puertos en el host (pruebas locales)
WEB_PORT=3000
API_PORT=3001
